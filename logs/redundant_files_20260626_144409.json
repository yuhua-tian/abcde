      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n╔══════════════════════════════════════════════════════════════════╗\n║       天启·阅读引擎 ReadingEngine v1.0                          ║\n║       负责阅读：公告 / 调研 / 财报 / 龙虎榜 / 资讯              ║\n║       读取 → DeepSeek 解读 → 存入阿里云盘知识库                 ║\n║       供系统分析、选股时调用                                      ║\n╚══════════════════════════════════════════════════════════════════╝\n\"\"\"\n\nimport os, sys, json, time, logging, hashlib\nfrom pathlib import Path\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Optional, Tuple\n\nimport requests\n\n# ── 保险库 ──\n_VAULT_password=[REDACTED]\nimport unified_auth\nunified_auth.init(_VAULT_PASSWORD)\nfrom unified_auth import CREDENTIALS, alidrive_upload\n\n# ── 配置 ──\nWORK_DIR = Path(\"/root/agent/mangueir\")\nREADING_DIR = WORK_DIR / \"reading_kb\"\nREADING_DIR.mkdir(parents=True, exist_ok=True)\n\nlogger = logging.getLogger(\"ReadingEngine\")\n\nDS = CREDENTIALS[\"deepseek\"]\n_session = requests.Session()\n_session.headers.update({\n    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'\n})\n\n# ═══════════════════════════════════════════════════════════════════\n# 知识库文件定义\n# ═══════════════════════════════════════════════════════════════════\n\nKB_FILES = {\n    \"announcement\": \"announcement_kb.json\",    # 公告知识库\n    \"research\":     \"research_kb.json\",         # 研报知识库\n    \"finance\":      \"finance_kb.json\",          # 财报知识库\n    \"dragon_tiger\": \"dragon_tiger_kb.json\",     # 龙虎榜知识库\n    \"news\":         \"news_kb.json\",             # 资讯知识库\n}\n\n# 云端知识库文件夹名（与天启主知识库区分，但同属阿里云盘）\nKB_FOLDER_NAME = \"天启知识库\"\n\n# ═══════════════════════════════════════════════════════════════════\n# 公告关键词分类\n# ═══════════════════════════════════════════════════════════════════\n\nANNOUNCEMENT_TYPES = {\n    \"业绩预告\": [\"业绩预告\", \"业绩预增\", \"业绩预减\", \"业绩预告披露\", \"盈利预测\",\n                 \"预计盈利\", \"预计亏损\", \"净利润\", \"同比增长\", \"同比下降