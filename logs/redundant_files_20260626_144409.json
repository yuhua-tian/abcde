      "content_sample": "#!/bin/bash\n# =============================================================================\n# 星河系统停止脚本\n# =============================================================================\n# 功能: 停止星河主程序 (xinghe.py)\n# 位置: /workspace/stop_red_queen.sh\n# 使用: ./stop_red_queen.sh\n# =============================================================================\n\n# 获取脚本所在目录\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n\n# 工作目录\nWORK_DIR=\"/root/agent/mangueir\"\n\n# 主程序名称\nMAIN_PROGRAM=\"xinghe.py\"\n\necho \"==========================================\"\necho \"         星河系统停止脚本\"\necho \"==========================================\"\necho \"\"\n\n# 检查是否在运行\nif ! pgrep -f \"${MAIN_PROGRAM}\" > /dev/null; then\n    echo \"[信息] 星河系统未在运行\"\n    exit 0\nfi\n\n# 获取当前进程ID\nCURRENT_PID=$(pgrep -f \"${MAIN_PROGRAM}\" | head -1)\necho \"[信息] 找到运行中的进程: $CURRENT_PID\"\n\n# 尝试优雅停止 (发送SIGTERM)\necho \"[信息] 正在停止星河系统...\"\n\n# 使用pkill尝试停止\nif pkill -f \"${MAIN_PROGRAM}\"; then\n    # 等待进程结束\n    sleep 2\n    \n    # 检查进程是否已停止\n    if pgrep -f \"${MAIN_PROGRAM}\" > /dev/null; then\n        echo \"[警告] 进程未响应，强制终止...\"\n        pkill -9 -f \"${MAIN_PROGRAM}\"\n        sleep 1\n    fi\n    \n    # 最终检查\n    if pgrep -f \"${MAIN_PROGRAM}\" > /dev/null; then\n        echo \"==========================================\"\n        echo \"  ✗ 星河停止失败\"\n        echo \"==========================================\"\n        echo \"\"\n        echo \"  仍运行的进程:\"\n        pgrep -f \"${MAIN_PROGRAM}\" | while read pid; do\n            echo \"    PID: $pid\"\n        done\n        echo \"\"\n        exit 1\n    else\n        echo \"==========================================\"\n        echo \"  ✓ 星河已停止\"\n        echo \"==========================================\"\n        echo \"\"\n        echo \"  停止时间: $(date '+%Y-%m-%d %H:%M:%S')\"\n        echo \"\"\n    fi\nelse\n    echo \"[错误] 停止进程失败\"\n    exit 1\nfi\n",
