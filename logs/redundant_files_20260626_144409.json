      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n红后 v5.0 一键升级工具\n升级到云端总控架构（大脑-手脚制）\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport shutil\nimport time\nimport urllib.request\nfrom pathlib import Path\n\nWORK_DIR = \"/opt/redqueen\"\nCONFIG_DIR = \"/opt/redqueen/work\"\n\n# 需要更新的文件列表（直接内联内容）\nFILES_TO_UPDATE = {}\n\n\ndef get_ai_router_v5():\n    return '''#!/usr/bin/env python3\n\"\"\"\nAI 路由调度器 v5.0 — 云端总控架构\n\n架构思想 (大脑-手脚制):\n    云端 API = 大脑 (主控) — 聪明、总决策、默认优先\n    本地天启 = 手脚 (执行) — 记忆管理、数据库、日志、工具执行、兜底\n\n云端（大脑）的职责:\n    1. 总控调度 — 分析用户问题，决定处理方式\n    2. 复杂问题 — 直接处理，给出高质量回答\n    3. 路由决策 — 判断该自己来还是让本地执行\n    4. 工具编排 — 指挥本地调用工具，整合结果\n\n本地（手脚）的职责:\n    1. 记忆管理 — 存储/检索对话记忆、长期记忆\n    2. 数据库操作 — 本地知识库、配置读写\n    3. 日志记录 — 记录所有交互和系统状态\n    4. 工具执行 — 按云端指令执行具体工具调用\n    5. 兜底摄政 — 云端掉线时，本地简单应付\n\n有网有API → 大脑说了算，手脚执行\n没网/API挂了 → 手脚摄政，简单应付\n\"\"\"\n\nimport re\nimport time\nimport json\nimport logging\nfrom typing import Dict, Optional, Tuple, List\nfrom dataclasses import dataclass\nfrom enum import Enum\n\nfrom config_manager import config\nfrom tianqi_local import get_tianqi, TianqiEngine, AIResponse\nfrom memory_system import get_memory, MemorySystem\n\nconfig.load()\n\nlogger = logging.getLogger(\"RedQueen.Router\")\n\n\nclass AIMode(Enum):\n    \"\"\"AI 模式\"\"\"\n    AUTO = \"auto\"           # 自动：云端总控，本地执行\n    CLOUD_ONLY = \"cloud\"    # 只用云端（大脑独断）\n    LOCAL_ONLY = \"local\"    # 只用本地（手脚主事）\n    OFFLINE = \"offline\"     # 离线模式（强制手脚摄政）\n\n\nclass CloudDecision(Enum):\n    \"\"\"云端决策结果\"\"\"\n    CLOUD_DIRECT = \"cloud_direct\"      # 云端直接回答\n    LOCAL_TOOL = \"local_tool\"          # 让本地执行工具\n    LOCAL_MEMORY = \"local_memory\"      # 让本地查记忆\n    LOCAL_KB = \"local_kb\"              # 让本地查知识库\n    FAILOVER = \"failover\"              # 云端失败，本地兜底\n\n\n@dataclass\nclass RouteStats:\n    \"\"\"路由统计\"\"\"\n    total_requests: int = 0\n    cloud_calls: int = 0\n    cloud_decision_calls: int = 0      # 云端决策调用（少量token）\n    cloud_answer_calls: int = 0        # 云端完整回答调用\n    local_calls: int = 0\n    tool_executions: int = 0\n    memory_queries: int = 0\n    kb_queries: int = 0\n    cloud_failovers: int = 0\n    total_tokens: int = 0",
