      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n╔══════════════════════════════════════════════════════════════════════╗\n║  data_fetcher.py — 数据抓取引擎                                     ║\n║  职责：股票行情 / K线 / 板块排行 / 动态主题发现                       ║\n║                                                                     ║\n║  数据源：腾讯财经（行情/K线）+ 同花顺（板块排行）                     ║\n╚══════════════════════════════════════════════════════════════════════╝\n\"\"\"\n\nimport re\nimport json\nimport time\nimport requests\nfrom typing import List, Dict, Tuple, Optional\nfrom datetime import datetime\n\nfrom root_code import (\n    get_logger, StockQuote, KLineBar, SectorInfo\n)\n\nlogger = get_logger(\"XingHe.DataFetcher\")\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# HTTP会话\n# ═══════════════════════════════════════════════════════════════════════\n\nSESSION = requests.Session()\nHEADERS = {\n    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',\n}\n\n\ndef _get_market_prefix(code: str) -> str:\n    \"\"\"获取股票市场前缀\"\"\"\n    if code.startswith(('6', '5', '9')):\n        return 'sh'\n    return 'sz'\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# 行情数据\n# ═══════════════════════════════════════════════════════════════════════\n\ndef fetch_stock_quotes(stock_list: List[Tuple[str, str]]) -> List[StockQuote]:\n    \"\"\"\n    从腾讯财经批量拉取股票行情\n    Args:\n        stock_list: [(code, name), ...]\n    Returns:\n        List[StockQuote]\n    \"\"\"\n    results = []\n    batch_size = 50\n\n    for i in range(0, len(stock_list), batch_size):\n        batch = stock_list[i:i + batch_size]\n        codes = [f'{_get_market_prefix(c)}{c}' for c, _ in batch]\n        url = f'http://qt.gtimg.cn/q={\",\".join(codes)}'\n\n        try:\n            resp = SESSION.get(url, timeout=15, headers=HEADERS)\n            if resp.status_code != 200:\n                continue\n\n            ",
