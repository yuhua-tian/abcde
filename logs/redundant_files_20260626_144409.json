ed).decode(\"ascii\")\n\n\ndef decrypt(ciphertext_b64: str, password=[REDACTED] -> dict:\n    \"\"\"\n    解密 Base64 密文为字典。\n    密码错误时抛出异常。\n    \"\"\"\n    key = ",
