      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n星河新闻引擎 v1.0 - 多源新闻采集 + 国际形势分析 + 情感分析\n数据源: 新闻联播/新华社/人民网/路透社/财联社\n\"\"\"\nimport re, json, time, logging\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Dict, List, Optional\nimport requests\n\nlogger = logging.getLogger(\"NewsEngine\")\n\nUA = 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'\n_SESSION = requests.Session()\n_SESSION.headers.update({'User-Agent': UA})\n\n# ── 新闻源配置 ──\nNEWS_SOURCES = {\n    'cls': {  # 财联社 - 电报快讯\n        'name': '财联社',\n        'url': 'https://www.cls.cn/api/sw?app=CailianpressWeb&os=web&sv=8.4.6',\n        'type': 'api',\n        'extractor': 'cls',\n    },\n    'xinhua': {  # 新华社\n        'name': '新华社',\n        'url': 'http://www.news.cn/politics/leaders/index.htm',\n        'type': 'html',\n        'extractor': 'xinhua',\n    },\n    'people': {  # 人民网\n        'name': '人民网',\n        'url': 'http://politics.people.com.cn/GB/1024/index.html',\n        'type': 'html',\n        'extractor': 'people',\n    },\n    'reuters': {  # 路透社中文\n        'name': '路透社',\n        'url': 'https://www.reuters.com/markets/',\n        'type': 'html',\n        'extractor': 'reuters',\n    },\n}\n\n# ── 国际形势关键词库 ──\nGEOPOLITICAL_KEYWORDS = {\n    '战争冲突': ['战争','军事','冲突','导弹','空袭','核','军队','演习','轰炸','入侵','自卫','武装','特种部队','海陆空'],\n    '制裁与贸易': ['制裁','关税','贸易战','禁运','封锁','脱钩','供应链','出口管制','技术封锁','黑名单','实体清单'],\n    '地缘政治': ['中东','伊朗','朝鲜','台海','南海','俄罗斯','北约','欧盟','东盟','金砖','G7','G20','一带一路'],\n    '能源与资源': ['石油','原油','天然气','能源','稀土','锂矿','铜矿','供应链','粮食','OPEC','减产'],\n    '经济与金融': ['美联储','加息','降息','通胀','GDP','衰退','债务','违约','汇率','人民币','美元','央行'],\n    '科技与AI': ['AI','人工智能','芯片','半导体','量子','5G','6G','太空','卫星','星链','航天','登月'],\n}\n\n# ── 新闻联播核心话题关键词 ──\nXINWENLIANBO_TOPICS = [\n    '习近平','总书记','国务院','政治局','常委','政策','改革','发展',\n    '新质生产力','高质量发展','科技','创新','制造','芯片','半导体',\n    '农业','粮食','乡村振兴','一带一路','外交','中非','中美','中欧',\n    '就业','民生','医保','教育','住房','减税',