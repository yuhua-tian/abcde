      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n天启引擎 v3.5 — 聪明的本地 AI\n\n为什么 API 比本地 AI 聪明？不只是算力，还有架构设计：\n1. RAG（检索增强生成）- 先搜知识库再回答\n2. 思维链（Chain of Thought）- 一步步拆解问题\n3. 工具使用（Tool Use）- 调用外部工具获取信息\n4. 反思机制（Reflection）- 做完检查结果\n5. 自我提示（Self-Prompting）- 自己构造合适的提示\n\n天启虽然算力不如 API，但这些架构思想一样可以用！\n\"\"\"\n\nimport re\nimport json\nimport time\nimport logging\nfrom typing import List, Dict, Optional, Tuple, Any\nfrom dataclasses import dataclass, field\n\nfrom config_manager import config\nfrom memory_system import get_memory, MemorySystem\nfrom tool_registry import registry, ToolResult\n\nlogger = logging.getLogger(\"RedQueen.Tianqi\")\n\n\n@dataclass\nclass ThoughtStep:\n    \"\"\"思维链的一步\"\"\"\n    step: int\n    thought: str\n    action: str = \"\"  # 要执行的动作\n    observation: str = \"\"  # 观察到的结果\n    conclusion: str = \"\"\n\n\nclass ChainOfThought:\n    \"\"\"\n    思维链引擎\n    模拟大模型的 Chain of Thought 推理\n    \"\"\"\n\n    def __init__(self):\n        self.steps: List[ThoughtStep] = []\n\n    def decompose(self, question: str) -> List[str]:\n        \"\"\"\n        把问题分解成子步骤\n        基于规则的简单分解\n        \"\"\"\n        steps = []\n\n        q = question.lower()\n\n        # 1. 理解问题\n        steps.append(\"理解问题：明确用户的需求是什么\")\n\n        # 2. 检查是否有相关知识\n        steps.append(\"检索记忆：看看有没有相关的知识或历史对话\")\n\n        # 3. 判断是否需要工具\n        need_tools = False\n        tool_keywords = [\"文件\", \"目录\", \"进程\", \"系统\", \"磁盘\", \"内存\",\n                         \"git\", \"代码\", \"ssh\", \"远程\", \"查看\", \"列出\"]\n        for kw in tool_keywords:\n            if kw in q:\n                need_tools = True\n                break\n\n        if need_tools:\n            steps.append(\"调用工具：使用合适的工具获取信息\")\n            steps.append(\"分析结果：整理工具返回的信息\")\n\n        # 4. 组织答案\n        steps.append(\"组织回答：把所有信息整理成清晰的答案\")\n\n        # 5. 反思检查\n        steps.append(\"反思检查：答案是否完整、准确、有用\")\n\n        return steps\n\n    def add_step(self, thought: str, action: str = \"\",\n                 observation: str = \"\", conclusion: str = \"\"):\n        \"\"\"添加一步思考\"\"\"\n        step = ThoughtStep(\n            step=len(self.steps) + 1,\n            thought=thought,\n            action=ac",
