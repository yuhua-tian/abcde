      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n红后内置工具集 v3.0\n所有工具通过 tool_registry 注册\n\n工具分类:\n- shell:    本地 Shell 命令执行\n- ssh:      SSH 远程命令执行\n- file:     文件操作\n- git:      Git 操作\n- system: 系统信息\n\"\"\"\n\nimport os\nimport subprocess\nimport shutil\nimport platform\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom tool_registry import registry\nfrom config_manager import config\n\n# ═══════════════════════════════════════════════════════════\n# 安全检查\n# ═══════════════════════════════════════════════════════════\n\nDEFAULT_DANGEROUS_PATTERNS = [\n    'rm -rf /', 'rm -rf /*', 'mkfs', 'dd if=',\n    ':(){ :|:& };:', '> /dev/sda', 'chmod 777 / -R',\n    'chmod -R 777 /', '.bash_history', 'cat /etc/shadow',\n    'sudo su', 'su root',\n]\n\n\ndef _is_dangerous(cmd: str) -> bool:\n    \"\"\"检查命令是否危险\"\"\"\n    cmd_lower = cmd.lower().strip()\n    if not cmd_lower:\n        return True\n    patterns = config.get(\"security.dangerous_patterns\", DEFAULT_DANGEROUS_PATTERNS)\n    for pattern in patterns:\n        if pattern.lower() in cmd_lower:\n            return True\n    if cmd_lower.startswith('rm -rf') and ('/' in cmd_lower or '*' in cmd_lower):\n        return True\n    return False\n\n\n# ═══════════════════════════════════════════════════════════\n# Shell 工具\n# ═══════════════════════════════════════════════════════════\n\n@registry.register(\"shell\", \"执行本地 Shell 命令\", \"shell\", {\"cmd\": \"命令字符串\"})\ndef shell_tool(cmd: str) -> dict:\n    \"\"\"执行本地 Shell 命令\"\"\"\n    if _is_dangerous(cmd):\n        return {\"error\": \"危险命令已阻止\", \"cmd\": cmd, \"success\": False}\n\n    timeout = config.get(\"tools.shell.timeout\", 30)\n    work_dir = config.get(\"tools.shell.work_dir\", \".\")\n\n    try:\n        result = subprocess.run(\n            cmd,\n            shell=True,\n            capture_output=True,\n            text=True,\n            timeout=timeout,\n            cwd=work_dir\n        )\n        return {\n            \"cmd\": cmd,\n            \"stdout\": result.stdout,\n            \"stderr\": result.stderr,\n            \"returncode\": result.returncode,\n            \"success\": r",
