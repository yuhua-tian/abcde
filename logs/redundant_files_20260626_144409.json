      "sha256": "5e351bf7335fe8d8cd136c81fb62d69f550668abc262df85dbc6c628cd6a742f",
      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n═══════════════════════════════════════════════════════════════════\n红后 墨菲技术分析引擎 v1.0\n═══════════════════════════════════════════════════════════════════\n基于 John J. Murphy 《期货市场技术分析》\n江湖外号: 技术分析\"圣经\"\n\n三大假设:\n  1. 市场行为包容消化一切\n  2. 价格以趋势方式演变\n  3. 历史会重演\n\n包含: 道氏理论 / 趋势分析 / 图表形态 / 量价分析 / 移动平均 / 振荡器\n═══════════════════════════════════════════════════════════════════\n\"\"\"\nimport numpy as np\nfrom typing import List, Dict, Tuple, Optional\nfrom dataclasses import dataclass, field\n\n\n# ═══════════════════════════════════════════════════════════════════\n# 1. 道氏理论 — 三重趋势\n# ═══════════════════════════════════════════════════════════════════\n\n@dataclass\nclass DowTheory:\n    \"\"\"\n    查尔斯·道 市场运动三层次:\n    - 主要趋势 (Primary): 持续一年以上，幅度20%+\n    - 次级趋势 (Secondary): 3周到3个月，回调1/3到2/3\n    - 短暂趋势 (Minor): 少于3周，噪音\n\n    道氏六条基本原则:\n    1. 三大运动\n    2. 主要趋势贯穿始终\n    3. 多头市场三阶段（积累/主升/狂热）\n    4. 空头市场三阶段（派发/恐慌/绝望）\n    5. 指数相互验证\n    6. 成交量验证趋势\n    \"\"\"\n    primary_trend: str = \"neutral\"     # bullish / bearish / neutral\n    secondary_trend: str = \"neutral\"\n    minor_trend: str = \"neutral\"\n    market_phase: str = \"\"             # 市场阶段\n\n    def analyze(self, closes: List[float]) -> None:\n        \"\"\"从收盘价判断三重趋势\"\"\"\n        n = len(closes)\n        if n < 60:\n            return\n\n        # 主要趋势: 60日均线方向\n        if n >= 60:\n            sma20 = np.mean(closes[-20:])\n            sma60 = np.mean(closes[-60:])\n            if sma20 > sma60 * 1.05:\n                self.primary_trend = \"bullish\"\n            elif sma20 < sma60 * 0.95:\n                self.primary_trend = \"bearish\"\n\n        # 次级趋势: 20日均线方向\n        if n >= 20:\n            sma5 = np.mean(closes[-5:])\n            sma20 = np.mean(closes[-20:])\n            if sma5 > sma20 * 1.02:\n                self.secondary_trend = \"bullish\"\n            elif sma5 < sma20 * 0.98:\n                self.secondary_trend = \"bearish\"\n\n        # 短暂趋势: 5日对比\n        if n >= 5:\n            if closes[-1] > closes[-5]:\n                self.minor_trend = \"bullish\"\n     ",
