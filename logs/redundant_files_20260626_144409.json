      "content_sample": "#!/bin/bash\n# ============================================================\n#  红后 v4.0 一键安装脚本\n#  皇帝皇后架构 + 记忆系统 + Telegram 机器人\n# ============================================================\n\nset -euo pipefail\n\n# 颜色\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m'\n\nlog_info()  { echo -e \"${BLUE}[INFO]${NC} $*\"; }\nlog_ok()    { echo -e \"${GREEN}[ OK ]${NC} $*\"; }\nlog_warn()  { echo -e \"${YELLOW}[WARN]${NC} $*\"; }\nlog_error() { echo -e \"${RED}[FAIL]${NC} $*\" >&2; }\n\nis_interactive() { [ -t 0 ]; }\n\necho -e \"${BLUE}\"\necho \"╔══════════════════════════════════════════════════╗\"\necho \"║     红后 v4.0 一键安装                            ║\"\necho \"║     皇帝皇后架构 + 记忆系统 + Telegram 机器人     ║\"\necho \"╚══════════════════════════════════════════════════╝\"\necho -e \"${NC}\"\necho \"\"\n\n# 安装目录\nINSTALL_DIR=\"${1:-/opt/redqueen}\"\nGIT_REPO=\"${GIT_REPO:-https://github.com/yuhua-tian/mangueir.git}\"\nGIT_BRANCH=\"${GIT_BRANCH:-main}\"\n\nlog_info \"安装目录: ${INSTALL_DIR}\"\necho \"\"\n\n# 1. 克隆仓库\nlog_info \"[1/5] 拉取最新代码...\"\nif [ -d \"$INSTALL_DIR/.git\" ]; then\n    echo \"  目录已存在，更新中...\"\n    cd \"$INSTALL_DIR\"\n    if ! git pull origin \"$GIT_BRANCH\"; then\n        log_warn \"git pull 失败，尝试重置...\"\n        git fetch origin \"$GIT_BRANCH\"\n        git reset --hard \"origin/$GIT_BRANCH\"\n    fi\nelif [ -d \"$INSTALL_DIR\" ]; then\n    log_warn \"目录已存在但不是 git 仓库，跳过代码拉取\"\n    cd \"$INSTALL_DIR\"\nelse\n    echo \"  克隆仓库...\"\n    git clone -b \"$GIT_BRANCH\" \"$GIT_REPO\" \"$INSTALL_DIR\"\n    cd \"$INSTALL_DIR\"\nfi\nlog_ok \"代码已就绪\"\necho \"\"\n\n# 2. 安装依赖\nlog_info \"[2/5] 安装 Python 依赖...\"\nif command -v python3 &> /dev/null; then\n    PYTHON=\"python3\"\nelse\n    log_error \"未找到 python3，请先安装 Python3\"\n    exit 1\nfi\n\nif command -v pip3 &> /dev/null; then\n    PIP=\"pip3\"\nelif command -v pip &> /dev/null; then\n    PIP=\"pip\"\nelse\n    log_error \"未找到 pip，请先安装 Python3-pip\"\n    exit 1\nfi\n\nPYTHON_VER=$($PYTHON -c 'import sys; print(\"%d.%d\" % sys.version_info[:2])')\necho \"  Python 版本: $PYTHON_VER\"\n\nPIP_LOG=\"$INSTALL_DIR/work/pip_install.log\"\nmkdir",
