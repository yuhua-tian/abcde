      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n═══════════════════════════════════════════════════════════════════\n红后 技术分析融合引擎 v1.0\n═══════════════════════════════════════════════════════════════════\n融合三本经典:\n  1. 《期货市场技术分析》 — John J. Murphy (技术分析\"圣经\")\n  2. 《混沌操作法》 — Bill Williams\n  3. 《证券交易新空间》 — Bill Williams\n\n双引擎并行:\n  墨菲引擎 (经典派) + 混沌引擎 (非线性派) → 综合评分\n═══════════════════════════════════════════════════════════════════\n\"\"\"\nimport json\nfrom datetime import datetime\nfrom typing import List, Dict, Optional, Tuple\n\nfrom chaos_engine import (\n    full_chaos_analysis, ChaosScore,\n    Alligator, Fractals, AwesomeOscillator, AcceleratorOscillator, BalanceLine,\n)\nfrom murphy_engine import (\n    full_murphy_analysis, MurphyScore,\n    DowTheory, TrendAnalysis, PatternRecognition,\n    VolumePriceAnalysis, MovingAverageSystem, OscillatorSystem,\n)\n\n# ═══════════════════════════════════════════════════════════════════\n# 融合评分\n# ═══════════════════════════════════════════════════════════════════\n\ndef fuse_analysis(highs: List[float], lows: List[float],\n                  closes: List[float], volumes: List[float] = None,\n                  code: str = \"\", name: str = \"\") -> Dict:\n    \"\"\"\n    双引擎融合分析\n    返回综合评分报告\n    \"\"\"\n    if volumes is None:\n        volumes = [0] * len(closes)\n\n    # 并行运行两个引擎\n    chaos = full_chaos_analysis(highs, lows, closes, volumes)\n    murphy = full_murphy_analysis(highs, lows, closes, volumes)\n\n    # 融合评分 (混沌:经典 = 40:60)\n    chaos_weight = 0.4\n    murphy_weight = 0.6\n    fused_total = chaos_weight * chaos.total + murphy_weight * murphy.total\n\n    # 综合信号\n    if fused_total > 0.6:\n        fused_signal = \"强烈看多\"\n    elif fused_total > 0.3:\n        fused_signal = \"看多\"\n    elif fused_total > 0.1:\n        fused_signal = \"偏多\"\n    elif fused_total > -0.1:\n        fused_signal = \"中性\"\n    elif fused_total > -0.3:\n        fused_signal = \"偏空\"\n    elif fused_total > -0.6:\n        fused_signal = \"看空\"\n    else:\n        fused_signal = \"强烈看空\"\n\n    # 信号一致性\n    if chaos.total > 0.2 and murphy.total > ",
