      "content_sample": "#!/bin/bash\n# ═══════════════════════════════════════════════════════════════════\n#  红后 AI Agent v2.0 — 一键部署脚本\n#  部署到服务器，让红后真正能干活\n# ═══════════════════════════════════════════════════════════════════\n\nset -euo pipefail\n\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m'\n\nlog_info()  { echo -e \"${BLUE}[INFO]${NC} $*\"; }\nlog_ok()    { echo -e \"${GREEN}[ OK ]${NC} $*\"; }\nlog_warn()  { echo -e \"${YELLOW}[WARN]${NC} $*\"; }\nlog_error() { echo -e \"${RED}[FAIL]${NC} $*\" >&2; }\n\necho \"\"\necho \"╔══════════════════════════════════════════════════╗\"\necho \"║     ★  红  后 AI v2.0  一键部署  ★               ║\"\necho \"║     RedQueen AI Agent Deploy                      ║\"\necho \"╚══════════════════════════════════════════════════╝\"\necho \"\"\n\n# ──────────────────────────────────────────────\n# 配置\n# ──────────────────────────────────────────────\nINSTALL_DIR=\"${INSTALL_DIR:-/root/agent/mangueir}\"\nWORK_DIR=\"${WORK_DIR:-/root/redqueen}\"\nLOG_DIR=\"$WORK_DIR/logs\"\nWEB_PORT=\"${WEB_PORT:-8080}\"\nAPI_PORT=\"${API_PORT:-8888}\"\nREQUIRED_FILES=(\"redqueen_agent.py\" \"redqueen_web.py\")\n\n# ──────────────────────────────────────────────\n# 1. 检查环境\n# ──────────────────────────────────────────────\nlog_info \"[1/7] 检查环境...\"\n\nif ! command -v python3 &> /dev/null; then\n    log_error \"Python3 未安装\"\n    exit 1\nfi\n\nPYTHON_VERSION=$(python3 --version)\necho \"  Python: $PYTHON_VERSION\"\n\nif command -v pip3 &> /dev/null; then\n    PIP=\"pip3\"\nelif command -v pip &> /dev/null; then\n    PIP=\"pip\"\nelse\n    log_error \"pip 未找到\"\n    exit 1\nfi\n\n# ──────────────────────────────────────────────\n# 2. 创建目录\n# ──────────────────────────────────────────────\nlog_info \"[2/7] 创建目录...\"\n\nmkdir -p \"$INSTALL_DIR\" \"$WORK_DIR/sessions\" \"$LOG_DIR\"\n\necho \"  代码目录: $INSTALL_DIR\"\necho \"  工作目录: $WORK_DIR\"\necho \"  日志目录: $LOG_DIR\"\n\n# ──────────────────────────────────────────────\n# 3. 安装依赖\n# ──────────────────────────────────────────────\nlog_info \"[3/7] 安装依赖...\"\n\nPIP_LOG=\"$LOG_DIR/pip_install.log\"\nif $PIP install --quiet ope",
