      "content_sample": "#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n天启v8.1 系统 - 代码医生模块 (CodeDoctor)\n============================================\n\n职责：代码健康检查、自我修复、优化建议\n功能：\n  1. 代码扫描 - 扫描所有.py文件，检查语法错误、潜在bug\n  2. 代码健康评分 - 给每个模块打分（复杂度 / 可维护性 / 错误处理 / 文档完整性）\n  3. 自动修复 - 修复简单的语法错误和常见问题\n  4. 优化建议 - 识别性能瓶颈，给出优化方案\n  5. 依赖分析 - 分析模块间依赖关系\n  6. 版本兼容 - 检查库版本兼容性\n\n作者：天启v8.1 系统\n日期：2026-06-22\n\"\"\"\n\nimport ast\nimport ast as ast_module\nimport importlib\nimport importlib.metadata\nimport json\nimport logging\nimport os\nimport re\nimport sys\nimport sysconfig\nimport tokenize\nimport traceback\nfrom collections import defaultdict, deque\nfrom dataclasses import dataclass, field, asdict\nfrom datetime import datetime\nfrom importlib.metadata import PackageNotFoundError, version as get_package_version\nfrom io import StringIO\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Set, Tuple, Union\n\n\n# ============================================================================\n# 数据类定义\n# ============================================================================\n\n@dataclass\nclass Issue:\n    \"\"\"代码问题记录\"\"\"\n    file: str                          # 文件路径\n    line: int                          # 行号\n    column: int                        # 列号\n    severity: str                      # 严重级别: 'error', 'warning', 'info'\n    category: str                      # 问题类别: 'syntax', 'bug', 'style', 'performance', 'security'\n    message: str                       # 问题描述\n    suggestion: str = \"\"               # 修复建议\n    auto_fixable: bool = False         # 是否可自动修复\n    code_snippet: str = \"\"             # 相关代码片段\n\n\n@dataclass\nclass HealthScore:\n    \"\"\"健康评分结果\"\"\"\n    file: str                          # 文件路径\n    overall: float                     # 综合评分 (0-100)\n    complexity: float                  # 复杂度评分\n    maintainability: float             # 可维护性评分\n    error_handling: float              # 错误处理评分\n    documentation: float               # 文档完整性评分\n    lines_of_code: int = 0             # 代码行数\n    num_functions: int = 0         ",
