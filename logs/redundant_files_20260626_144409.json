      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n红后记忆系统 v3.0 — 解决 AI 失忆问题\n\n记忆分层:\n    1. 感觉记忆 (Sensory)  - 原始输入，几秒内遗忘\n    2. 短期记忆 (Working)  - 当前对话上下文，有限容量\n    3. 长期记忆 (Long-term)\n       ├─ 情景记忆 (Episodic)  - 历史对话摘要、重要事件\n       ├─ 语义记忆 (Semantic)  - 知识、概念、事实\n       └─ 程序记忆 (Procedural) - 技能、操作流程\n\n核心机制:\n    - 记忆编码: 自动提取要点、打标签\n    - 记忆检索: 相似度搜索 + 时间衰减\n    - 记忆巩固: 定期摘要、迁移到长期记忆\n    - 记忆遗忘: 不重要的记忆逐渐淡化\n    - 记忆日志: 所有记忆变更可追溯\n\"\"\"\n\nimport os\nimport re\nimport json\nimport time\nimport hashlib\nimport logging\nfrom pathlib import Path\nfrom typing import List, Dict, Optional, Tuple, Any\nfrom dataclasses import dataclass, field, asdict\nfrom datetime import datetime, timedelta\nfrom enum import Enum\n\nfrom config_manager import config\n\nlogger = logging.getLogger(\"RedQueen.Memory\")\n\n\nclass MemoryType(Enum):\n    \"\"\"记忆类型\"\"\"\n    SENSORY = \"sensory\"        # 感觉记忆\n    WORKING = \"working\"        # 短期/工作记忆\n    EPISODIC = \"episodic\"      # 情景记忆（事件、对话）\n    SEMANTIC = \"semantic\"      # 语义记忆（知识、事实）\n    PROCEDURAL = \"procedural\"  # 程序记忆（技能、流程）\n\n\nclass MemoryImportance(Enum):\n    \"\"\"记忆重要程度\"\"\"\n    TRIVIAL = 0     # 琐碎，很快遗忘\n    LOW = 1         # 低重要性\n    MEDIUM = 2      # 中等\n    HIGH = 3        # 高重要性\n    CRITICAL = 4    # 关键，永久保留\n\n\n@dataclass\nclass Memory:\n    \"\"\"单条记忆\"\"\"\n    id: str\n    type: str  # MemoryType.value\n    content: str\n    summary: str = \"\"\n    tags: List[str] = field(default_factory=list)\n    importance: int = 2  # MemoryImportance.value\n    source: str = \"unknown\"  # user / api / system / auto\n    related_to: List[str] = field(default_factory=list)  # 关联记忆ID\n    metadata: Dict[str, Any] = field(default_factory=dict)\n\n    created_at: str = \"\"\n    last_accessed: str = \"\"\n    access_count: int = 0\n    decay_rate: float = 0.01  # 每天遗忘速率\n    strength: float = 1.0     # 当前强度（0-1）\n\n    def __post_init__(self):\n        now = datetime.now().isoformat()\n        if not self.created_at:\n            self.created_at = now\n        if not self.last_accessed:\n            self.last_accessed = now\n\n    def access(self):\n     ",
