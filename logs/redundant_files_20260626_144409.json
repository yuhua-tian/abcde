      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n═══════════════════════════════════════════════════════════════════\n红后 混沌操作法引擎 v1.0\n═══════════════════════════════════════════════════════════════════\n基于 Bill Williams 混沌操作法 (Trading Chaos) + 证券交易新空间\n五大维度: 鳄鱼线 → 分形 → AO动量 → AC加速 → 均衡线\n\n核心思想: 市场是非线性的混沌系统，但混沌中存在可识别模式。\n═══════════════════════════════════════════════════════════════════\n\"\"\"\nimport numpy as np\nfrom typing import List, Dict, Tuple, Optional\nfrom dataclasses import dataclass, field\n\n\n# ═══════════════════════════════════════════════════════════════════\n# 1. 鳄鱼线 (Alligator) — 第一维度：趋势识别\n# ═══════════════════════════════════════════════════════════════════\n\n@dataclass\nclass Alligator:\n    \"\"\"\n    鳄鱼线 = 三条平滑移动平均线，各自向未来平移\n    蓝线(颚/Jaw):   SMMA(13) 右移8 → 周线级别平衡线\n    红线(齿/Teeth): SMMA(8)  右移5 → 日线级别平衡线\n    绿线(唇/Lips):  SMMA(5)  右移3 → 小时级别平衡线\n\n    状态:\n    - 睡觉: 三条线缠绕交错 → 无趋势，观望\n    - 醒来: 唇线率先张开 → 准备入场\n    - 进食: 三条线发散排列 → 顺势持有\n    - 吃饱: 三条线开始收敛 → 准备离场\n    \"\"\"\n    jaw: List[float] = field(default_factory=list)    # 蓝线\n    teeth: List[float] = field(default_factory=list)   # 红线\n    lips: List[float] = field(default_factory=list)    # 绿线\n\n    def compute(self, closes: List[float]) -> None:\n        \"\"\"从收盘价序列计算鳄鱼线\"\"\"\n        n = len(closes)\n        if n < 13:\n            return\n\n        # SMMA = 指数平滑移动平均 (EMA)\n        def smma(data, period):\n            alpha = 2.0 / (period + 1)\n            result = [data[0]]\n            for i in range(1, len(data)):\n                result.append(alpha * data[i] + (1 - alpha) * result[-1])\n            return result\n\n        # 计算各周期SMMA并右移\n        jaw_raw = smma(closes, 13)\n        teeth_raw = smma(closes, 8)\n        lips_raw = smma(closes, 5)\n\n        # 右移（向未来方向移动，用NaN填充）\n        self.jaw = [float('nan')] * 8 + jaw_raw[:n-8] if n > 8 else [float('nan')] * n\n        self.teeth = [float('nan')] * 5 + teeth_raw[:n-5] if n > 5 else [float('nan')] * n\n        self.lips = [float('nan')] * 3 + lips_raw[:n-3] if n > 3 else [float('nan')] * n\n\n    def get_state(self,",
