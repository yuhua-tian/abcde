      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n╔══════════════════════════════════════════════════════════════════════╗\n║  05_database.py — 数据库                                            ║\n║  职责：所有资料整合 — 财经日历 / 新闻 / 技术分析 / 行情 / 股票信息   ║\n║                                                                     ║\n║  数据来源：用户提供的第五份定义文件 + 现有系统所有资料                 ║\n║  角色：红后超级AI的数据底座，提供所有市场数据                         ║\n╚══════════════════════════════════════════════════════════════════════╝\n\"\"\"\n\nimport json\nimport sqlite3\nimport logging\nfrom pathlib import Path\nfrom datetime import datetime, timedelta\nfrom typing import List, Dict, Optional, Any, Tuple\nfrom dataclasses import dataclass, asdict\nfrom contextlib import contextmanager\n\nfrom root_code import (\n    WORK_DIR, DB_DIR, get_logger,\n    StockInfo, MarketSnapshot, TradingSignal, DatabaseError,\n    ThematicChain, StockQuote, KLineBar, SectorInfo, MineScanResult\n)\n\nlogger = get_logger(\"XingHe.Database\")\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# 数据库引擎\n# ═══════════════════════════════════════════════════════════════════════\n\nclass Database:\n    \"\"\"数据库 — 系统所有资料的统一存储\"\"\"\n\n    DB_PATH = DB_DIR / \"xinghe.db\"\n\n    # ── 初始化 ──────────────────────────────────────────────────────\n\n    def __init__(self, db_path: Path = None):\n        self._db_path = db_path or self.DB_PATH\n        self._db_path.parent.mkdir(parents=True, exist_ok=True)\n\n        # 内存缓存\n        self._thematic_chains: Dict[str, ThematicChain] = {}\n        self._event_triggers: List[Dict] = []\n        self._quote_cache: Dict[str, StockQuote] = {}  # 实时行情缓存\n        self._kline_cache: Dict[str, List[KLineBar]] = {}  # K线缓存\n\n        self._init_tables()\n        self._seed_core_knowledge()\n        self._seed_thematic_chains()\n        self._seed_event_triggers()\n\n    @contextmanager\n    def _get_conn(self):\n        \"\"\"获取数据库连接（上下文管理器）\"\"\"\n        conn = sqlite3.connect(str(self._db_path))\n        conn.row_factory = sqlite3.Row\n        try:\n            yield conn\n",
