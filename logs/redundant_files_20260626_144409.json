      "content_sample": "#!/bin/bash\n# ═══════════════════════════════════════════════════════════════════\n# 星河 v9.0 + 天启 Telegram Bot — systemd 一键部署\n# 架构: 星河(躯壳) · 天启(灵魂) · 红后(管理员)\n# 用法: bash install_services.sh\n# ═══════════════════════════════════════════════════════════════════\nset -euo pipefail\n\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m'\n\nlog_info()  { echo -e \"${BLUE}[INFO]${NC} $*\"; }\nlog_ok()    { echo -e \"${GREEN}[ OK ]${NC} $*\"; }\nlog_warn()  { echo -e \"${YELLOW}[WARN]${NC} $*\"; }\nlog_error() { echo -e \"${RED}[FAIL]${NC} $*\" >&2; }\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nSYSTEMD_DIR=\"/etc/systemd/system\"\nINSTALL_DIR=\"${INSTALL_DIR:-/root/agent/mangueir}\"\nLOG_DIR=\"${LOG_DIR:-$INSTALL_DIR/logs}\"\n\nSERVICES=(\n    \"xinghe\"\n    \"tianqi-telegram-bot\"\n)\n\necho \"\"\necho \"=== 星河 v9.0 & 天启系统服务部署 ===\"\necho \"    星河(躯壳) · 天启(灵魂) · 红后(管理员)\"\necho \"\"\n\n# 0. 权限检查\nif [ \"$(id -u)\" -ne 0 ]; then\n    log_error \"此脚本需要 root 权限运行\"\n    echo \"  请使用: sudo bash $0\"\n    exit 1\nfi\n\n# 1. 确保日志目录存在\nlog_info \"创建日志目录...\"\nmkdir -p \"$LOG_DIR\"\nlog_ok \"日志目录: $LOG_DIR\"\necho \"\"\n\n# 2. 检查 service 文件是否存在\nlog_info \"检查 service 文件...\"\nfor svc in \"${SERVICES[@]}\"; do\n    svc_file=\"$SCRIPT_DIR/${svc}.service\"\n    if [ ! -f \"$svc_file\" ]; then\n        log_error \"缺少 service 文件: $svc_file\"\n        exit 1\n    fi\n    log_ok \"${svc}.service 存在\"\ndone\necho \"\"\n\n# 3. 停掉现有的 nohup 进程\nstop_legacy_process() {\n    local pattern=\"$1\"\n    local -a pids\n    mapfile -t pids < <(pgrep -f \"$pattern\" 2>/dev/null || true)\n    if [ ${#pids[@]} -gt 0 ]; then\n        log_info \"停止旧进程: $pattern\"\n        kill \"${pids[@]}\" 2>/dev/null || true\n        sleep 2\n        local -a remaining\n        mapfile -t remaining < <(pgrep -f \"$pattern\" 2>/dev/null || true)\n        if [ ${#remaining[@]} -gt 0 ]; then\n            log_warn \"进程未停止，强制终止...\"\n            kill -9 \"${remaining[@]}\" 2>/dev/null || true\n        fi\n    fi\n}\n\nstop_legacy_process \"xinghe.py\"\nstop_legacy_process \"tianqi_telegram_bot.py\"\necho \"\"\n\n# 4. 停止已有的 syst",
