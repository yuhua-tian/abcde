      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n╔══════════════════════════════════════════════════════════════════════╗\n║  04_runtime_logic.py — 运行逻辑                                     ║\n║  职责：主循环 / 调度引擎 / 市场规律引擎 / 月份题材节奏 / 龙头战法     ║\n║                                                                     ║\n║  数据来源：用户提供的第四份定义文件                                   ║\n║  角色：系统运行时的调度中心 + 市场规律知识库                          ║\n║                                                                     ║\n║  核心定律：股市是混沌的但是也是有规律的                               ║\n║  题材规律（六一中路）→ 月份季节性规律                                ║\n║  龙头战法 → 转龙/对标/竞价/第几板/活在当下                          ║\n╚══════════════════════════════════════════════════════════════════════╝\n\"\"\"\n\nimport time\nimport threading\nfrom datetime import datetime, date, time as dtime\nfrom typing import Optional, Dict, Any, List, Tuple\nfrom pathlib import Path\nfrom enum import Enum\n\nfrom root_code import (\n    WORK_DIR, LOG_DIR, get_logger,\n    is_trading_day, format_duration\n)\n\nlogger = get_logger(\"XingHe.Runtime\")\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# 市场周期阶段定义\n# ═══════════════════════════════════════════════════════════════════════\n\nclass MarketPhase(Enum):\n    \"\"\"市场周期阶段 — 对应九段循环论\"\"\"\n    BREWING = \"brewing\"       # 酝酿\n    START = \"start\"           # 启动\n    DIFFUSION = \"diffusion\"   # 扩散\n    CLIMAX = \"climax\"         # 高潮\n    PEAK = \"peak\"             # 盛极\n    AVALANCHE = \"avalanche\"   # 雪崩\n    ESCAPE = \"escape\"         # 出逃\n    SILENCE = \"silence\"       # 死寂\n    REBIRTH = \"rebirth\"       # 重生\n\n\nclass MarketMood(Enum):\n    \"\"\"市场四动态 — 情绪与行为对应\"\"\"\n    GREED_GREED = \"greed_greed\"     # 别人贪婪我更贪婪 → 主线行情，赚钱效应\n    GREED_FEAR = \"greed_fear\"        # 别人贪婪我恐惧 → 人声鼎沸，盛极而衰，逃顶\n    FEAR_FEAR = \"fear_fear\"          # 别人恐惧我更恐惧 → A杀时刻，轮动杀猪盘\n    FEAR_GREED = \"fear_greed\"        # 别人恐惧我贪婪 → 情绪冰点，阴极阳生，抄底\n\n\n# ═══════════════════════════════════════════════════════════════════════\n# 月份题材规律引擎 (题材规律 by 六一中路)\n# ════════════════════════════════════════",
