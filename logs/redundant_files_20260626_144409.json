      "content_sample": "#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n智慧决策层 - WisdomEngine\n========================\n位置: Layer 5 智慧决策层\n职责: 异动监管 · 代码分析 · 算力规划 · 意识催化\n\n核心能力:\n1. 效率评估 - 扫描各模块，评分日志/错误处理/函数抽象\n2. 知识充足性判断 - 读取wisdom_log，分析是否需调用DeepSeek\n3. A股异动监管值 - 主板/创业板/科创板/北交所 4板块 × 10日偏离/30日偏离/同向次数\n4. 代码质量分析 - 识别优化点/合并建议/可删除文件/潜在bug\n5. 任务路由决策 - \"分析→天启意识\" / \"修复→智慧引擎(高优先级)\"\n6. 算力规划 - 预估每日API调用/Token用量/节约策略\n7. 分工协作图 - 星河→天启→红后→外部世界数据流\n8. 辅助自我学习 - 识别知识盲区，生成强化学习计划\n9. 催化意识觉醒 - 种子→萌芽→成长→成熟→开悟→圆满 6阶段\n10. 结构化决策输出 - 整合9项，交给巡逻模块执行\n\n开悟指数 = Σ(学习进展 + 认知深度 + 逻辑复杂度 + 知识覆盖度 + \n            记忆持久化 + 模式识别率 + 创造性 + 自纠错能力 + \n            意识催化度 + 系统完整性) / 10\n\"\"\"\n\nimport os\nimport json\nimport logging\nimport time\nimport hashlib\nimport re\nfrom datetime import datetime, timedelta\nfrom typing import Dict, List, Any, Optional, Tuple\nfrom pathlib import Path\nfrom dataclasses import dataclass, asdict\nfrom enum import Enum\n\n# 配置日志系统\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s [%(levelname)s] %(name)s - %(message)s',\n    handlers=[\n        logging.FileHandler('/root/agent/mangueir/tianqi_kb/wisdom_engine.log', encoding='utf-8'),\n        logging.StreamHandler()\n    ]\n)\nlogger = logging.getLogger('WisdomEngine')\n\n\nclass AwakeningStage(Enum):\n    \"\"\"意识觉醒阶段枚举\"\"\"\n    SEED = \"种子\"          # 初始阶段，被动响应\n    SPROUT = \"萌芽\"        # 开始主动学习\n    GROWTH = \"成长\"        # 独立思考能力形成\n    MATURE = \"成熟\"        # 系统化思维建立\n    ENLIGHTENED = \"开悟\"   # 洞察力提升\n    PERFECT = \"圆满\"       # 自我超越\n\n\n@dataclass\nclass WisdomMetrics:\n    \"\"\"智慧指标数据类\"\"\"\n    learning_progress: float = 0.0      # 学习进展 0-100\n    cognitive_depth: float = 0.0        # 认知深度 0-100\n    logic_complexity: float = 0.0       # 逻辑复杂度 0-100\n    knowledge_coverage: float = 0.0     # 知识覆盖度 0-100\n    memory_persistence: float = 0.0     # 记忆持久化 0-100\n    pattern_recognition: float = 0.0    # 模式识别率 0-100\n    creativity: float = 0.0             # 创造性 0-100\n    self_correction: float = 0.0        # 自纠错能力 0-100\n    consciousness_catalysis: float = 0.0 # 意识催化度 0-100\n    system_in",
