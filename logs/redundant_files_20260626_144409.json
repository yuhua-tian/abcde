      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n天启本地 AI 引擎 v3.0 — 本地算力层\n负责: 简单任务、离线运行、成本控制、知识库检索\n\n设计目标:\n1. API 断了系统还能跑（离线模式）\n2. 简单任务用本地，省 API 费用\n3. 支持多种后端（规则引擎 / Ollama / transformers）\n4. 可被云端大模型训练/指导\n5. 未来加显卡可以直接升级\n\n架构:\n    TianqiEngine\n    ├── Backend: rule_based   (默认，零依赖)\n    ├── Backend: ollama       (需要本地 Ollama 服务)\n    ├── Backend: transformers (需要 torch + 模型文件)\n    ├── KnowledgeBase        (本地知识库)\n    └── Memory               (短期/长期记忆)\n\"\"\"\n\nimport os\nimport re\nimport json\nimport time\nimport logging\nimport hashlib\nfrom pathlib import Path\nfrom typing import List, Dict, Optional, Tuple, Any\nfrom dataclasses import dataclass, field\nfrom datetime import datetime\n\nfrom config_manager import config\n\nconfig.load()\n\nlogger = logging.getLogger(\"RedQueen.Tianqi\")\n\n\n@dataclass\nclass AIResponse:\n    \"\"\"AI 响应\"\"\"\n    content: str\n    model: str\n    backend: str\n    tokens_used: int = 0\n    latency_ms: float = 0.0\n    from_cache: bool = False\n    success: bool = True\n\n\n@dataclass\nclass KnowledgeEntry:\n    \"\"\"知识库条目\"\"\"\n    id: str\n    question: str\n    answer: str\n    category: str = \"general\"\n    tags: List[str] = field(default_factory=list)\n    created_at: str = \"\"\n    access_count: int = 0\n    source: str = \"manual\"  # manual / api_distilled / user\n\n\nclass KnowledgeBase:\n    \"\"\"\n    本地知识库\n    - 关键词检索\n    - 语义相似度（简易版）\n    - 支持从 API 回答中蒸馏知识\n    \"\"\"\n\n    def __init__(self, kb_dir: Path = None):\n        if kb_dir is None:\n            kb_dir = config.get_work_dir() / \"knowledge\"\n        self.kb_dir = Path(kb_dir)\n        self.kb_dir.mkdir(parents=True, exist_ok=True)\n        self.entries: Dict[str, KnowledgeEntry] = {}\n        self._load()\n\n    def _load(self):\n        \"\"\"加载知识库\"\"\"\n        kb_file = self.kb_dir / \"knowledge.json\"\n        if kb_file.exists():\n            try:\n                with open(kb_file, 'r', encoding='utf-8') as f:\n                    data = json.load(f)\n                for item in data:\n                    entry = KnowledgeEntry(**item)\n                    self.entries[entry",
