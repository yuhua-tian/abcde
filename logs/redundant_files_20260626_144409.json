      "content_sample": "#!/bin/bash\n# =============================================================================\n# 星河系统 v9.0 启动脚本\n# =============================================================================\n# 架构: 星河(躯壳) · 天启(灵魂·DeepSeek) · 红后(管理员)\n# 用法: ./start.sh                  # nohup 后台启动\n#       systemctl start xinghe       # systemd 启动（推荐）\n# =============================================================================\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nWORK_DIR=\"/root/agent/mangueir\"\nMAIN_PROGRAM=\"xinghe.py\"\nLOG_FILE=\"${WORK_DIR}/xinghe.log\"\n\necho \"==========================================\"\necho \"    星河系统 v9.0 — 三位一体\"\necho \"    躯壳(星河) · 灵魂(天启) · 管理员(红后)\"\necho \"==========================================\"\necho \"\"\n\nif [ ! -d \"$WORK_DIR\" ]; then\n    echo \"[错误] 工作目录不存在: $WORK_DIR\"\n    exit 1\nfi\n\nif [ ! -f \"${WORK_DIR}/${MAIN_PROGRAM}\" ]; then\n    echo \"[错误] 主程序不存在: ${WORK_DIR}/${MAIN_PROGRAM}\"\n    exit 1\nfi\n\nif pgrep -f \"${MAIN_PROGRAM}\" > /dev/null; then\n    echo \"[警告] 星河系统已在运行中\"\n    echo \"当前进程: $(pgrep -f ${MAIN_PROGRAM})\"\n    echo \"\"\n    echo \"如需重启: ./stop_red_queen.sh && ./start.sh\"\n    exit 1\nfi\n\ncd \"$WORK_DIR\"\nmkdir -p \"$(dirname \"$LOG_FILE\")\"\n\necho \"[信息] 正在启动星河系统 v9.0...\"\necho \"[信息] 工作目录: $WORK_DIR\"\necho \"[信息] 日志文件: $LOG_FILE\"\necho \"[信息] 启动时间: $(date '+%Y-%m-%d %H:%M:%S')\"\necho \"\"\n\nnohup python3 \"${WORK_DIR}/${MAIN_PROGRAM}\" >> \"$LOG_FILE\" 2>&1 &\nPID=$!\nsleep 1\n\nif ps -p $PID > /dev/null 2>&1; then\n    echo \"==========================================\"\n    echo \"  ✓ 星河 v9.0 已成功启动\"\n    echo \"==========================================\"\n    echo \"\"\n    echo \"  进程ID: $PID\"\n    echo \"  日志文件: $LOG_FILE\"\n    echo \"\"\n    echo \"  查看日志: tail -f $LOG_FILE\"\n    echo \"  停止程序: ./stop_red_queen.sh\"\n    echo \"  检查状态: ./status_red_queen.sh\"\n    echo \"\"\n    echo \"  ★ 推荐使用 systemd 以持久运行:\"\n    echo \"    bash install_services.sh\"\n    echo \"\"\n    echo \"==========================================\"\nelse\n    echo \"==========================================\"\n    echo \"  ✗ 星河启动",
