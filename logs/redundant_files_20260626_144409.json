      "content_sample": "#!/usr/bin/env python3\n\"\"\"\nAI 路由调度器 v6.0 — 本地优先，渐进升级架构\n\n架构原则:\n  能本地处理的，绝不花冤枉钱调用云端\n  逐层升级，从快到慢，从免费到付费\n\n处理层级（按优先级）:\n  1. 缓存层    → 毫秒级，免费，内存缓存\n  2. 知识库层   → 毫秒级，免费，本地知识库\n  3. 工具执行层   → 秒级，免费，本地工具（shell/file/git/system...）\n  4. 本地模型层  → 秒级，免费，Ollama/GPU本地推理\n  5. 云端API层  → 秒级，付费，云端大模型\n\n特色:\n  - 部分处理：本地能做的先做（查日志/查文件/执行命令），剩下分析总结给云端\n  - 知识蒸馏：云端回答自动沉淀到本地知识库，越用越省\n\"\"\"\n\nimport re\nimport time\nimport json\nimport logging\nfrom typing import Dict, Optional, Tuple, List\nfrom dataclasses import dataclass, field\nfrom enum import Enum\n\nfrom config_manager import config\nfrom tianqi_local import get_tianqi, TianqiEngine, AIResponse\nfrom memory_system import get_memory, MemorySystem\n\nconfig.load()\n\nlogger = logging.getLogger(\"RedQueen.Router\")\n\n\nclass AIMode(Enum):\n    \"\"\"AI 模式\"\"\"\n    LOCAL_FIRST = \"local_first\"  # 本地优先（默认，省钱模式）\n    CLOUD_FIRST = \"cloud_first\"   # 云端优先（快速模式）\n    LOCAL_ONLY = \"local_only\"   # 纯本地（离线模式）\n    CLOUD_ONLY = \"cloud_only\"    # 纯云端（强制付费模式）\n\n\nclass ProcessLayer(Enum):\n    \"\"\"处理层级\"\"\"\n    CACHE = \"cache\"\n    KNOWLEDGE = \"knowledge\"\n    TOOL = \"tool\"\n    LOCAL_MODEL = \"local_model\"\n    CLOUD = \"cloud\"\n\n\n@dataclass\nclass RouteStats:\n    \"\"\"路由统计\"\"\"\n    total_requests: int = 0\n    cache_hits: int = 0\n    kb_hits: int = 0\n    tool_executions: int = 0\n    local_model_calls: int = 0\n    cloud_calls: int = 0\n    partial_local: int = 0        # 本地部分处理\n    cloud_failovers: int = 0     # 云端失败兜底\n    total_tokens: int = 0\n    total_latency_ms: float = 0.0\n    cost_saved_estimate: float = 0.0  # 估算节省的费用\n\n    @property\n    def avg_latency(self) -> float:\n        if self.total_requests == 0:\n            return 0\n        return self.total_latency_ms / self.total_requests\n\n    @property\n    def local_hit_ratio(self) -> float:\n        \"\"\"本地处理率（缓存+知识库+本地模型）/总请求\"\"\"\n        if self.total_requests == 0:\n            return 0\n        return (self.cache_hits + self.kb_hits + self.local_model_calls) / self.total_requests\n\n    def to_dict(self) -> dict:\n        return {\n            \"total_reques",
