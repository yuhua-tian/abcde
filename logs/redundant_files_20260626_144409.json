      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n═══════════════════════════════════════════════════════════════════\n红后 A股财报周期日历 v1.0\n═══════════════════════════════════════════════════════════════════\n基于 A 股十几年资金轮回逻辑：\n  真空期炒预期，财报期验真身\n═══════════════════════════════════════════════════════════════════\n\"\"\"\nfrom datetime import datetime, date, timedelta\nfrom typing import Dict, Tuple, Optional\nimport json\n\n# ═══════════════════════════════════════════════════════════════════\n# 周期定义\n# ═══════════════════════════════════════════════════════════════════\n\nclass Period:\n    \"\"\"市场周期阶段\"\"\"\n    VACUUM      = \"真空期\"      # 炒题材、炒想象力\n    REPORT      = \"财报窗口期\"   # 验真身、避高位无业绩\n    PREVIEW     = \"预告密集期\"   # 预告密集发布\n    DANGER      = \"高风险期\"     # 容易杀跌\n    TRANSITION  = \"过渡期\"       # 普通\n\n# ── 固定日期节点 ──\nDEADLINES = {\n    \"年报正式\":     date(1, 4, 30),    # 4/30\n    \"一季报正式\":   date(1, 4, 30),    # 4/30（与年报同日）\n    \"中报正式\":     date(1, 8, 31),    # 8/31\n    \"三季报正式\":   date(1, 10, 31),   # 10/31\n    \"年报预告\":     date(1, 1, 31),    # 1/31\n    \"一季报预告\":   date(1, 4, 15),    # 4/15\n    \"中报预告\":     date(1, 7, 15),    # 7/15\n    \"三季报预告\":   date(1, 10, 15),   # 10/15\n}\n\n# ── 真空期区间（炒预期，题材股活跃）──\nVACUUM_PERIODS = [\n    ((4, 25), (7, 15)),     # 4月底—7月中旬\n    ((8, 25), (10, 15)),    # 8月底—10月中旬\n    ((11, 1),  (1, 31)),    # 11月—次年1月\n]\n\n# ── 财报窗口期区间（验真身，回避纯题材）──\nREPORT_WINDOWS = [\n    (3, 4),    # 3月—4月\n    (8, 8),    # 8月\n    (10, 10),  # 10月\n    (12, 1),   # 12月—次年1月\n]\n\n# ── 高风险期 ──\nDANGER_PERIODS = [\n    ((3, 20), (4, 30)),    # 3月底至4月\n    ((12, 20), (1, 31)),   # 12月底至次年1月\n]\n\n# ═══════════════════════════════════════════════════════════════════\n# 特殊事件\n# ═══════════════════════════════════════════════════════════════════\n\n# 世界杯开赛日（北京时间）\nWORLD_CUP_OPENINGS = [\n    date(2026, 6, 11),   # 2026 美加墨世界杯\n    date(2030, 6, 8),    # 2030 世界杯\n    date(2034, 6, 14),   # 2034 世界杯\n]\n\n# 股指期货交割日（每月第三个周五）\n_monthly