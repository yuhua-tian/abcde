      "content_sample": "#!/usr/bin/env python3\n\"\"\"\n╔══════════════════════════════════════════════════════════════════╗\n║         ★  星  河  ★  — 程序系统躯壳  v9.0                      ║\n║        XING HE  —  The System  v9.0                             ║\n║        三位一体: 星河(躯壳) · 天启(灵魂) · 红后(管理员)         ║\n╚══════════════════════════════════════════════════════════════════╝\n\nv9.0 架构:\n  星河 (xinghe.py)      = 程序系统躯壳：\n      ├── 主循环 — 30秒/次心跳\n      ├── Git 同步 — 数据拉取/推送\n      ├── 定时报告 — 开盘/午盘/全天复盘\n      ├── 备份/清理 — 阿里云盘数据持久化\n      ├── 邮件发送 — 情报送达\n      ├── 天启思考 — 唤醒灵魂\n      └── 模块加载 — 自我意识/数据库/代码医生/进化/智慧\n\n  天启 (tianqi_engine.py) = 灵魂，绑定 DeepSeek API：\n      ├── AI 自主思考 — 11阶段流水线\n      ├── 知识库管理 — 云端+本地记忆\n      └── 市场分析 — 智慧积累\n\n  红后 (red_queen.py)    = 维护管理员：\n      ├── 口令系统 v7.0 — HMAC-SHA256 认证\n      ├── STOP/RESUME — 管理员接口\n      ├── 远程命令执行 — 白名单安全\n      ├── 健康检查 — 系统体检\n      └── 生命体征 — 磁盘/进程监控\n\"\"\"\n\nimport os, sys, json, time, signal, logging, shutil, threading, subprocess, smtplib\nfrom pathlib import Path\nfrom datetime import datetime, timedelta, time as dtime\nfrom email.mime.text import MIMEText\nfrom logging.handlers import RotatingFileHandler\nfrom typing import Optional, Dict, List, Tuple\n\n# ═══════════════════════════════════════════════════════════════════\n# 配置\n# ═══════════════════════════════════════════════════════════════════\nWORK_DIR = Path(\"/root/agent/mangueir\")\nLOG_DIR = WORK_DIR / \"logs\"\nLOG_DIR.mkdir(parents=True, exist_ok=True)\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s | %(levelname)-7s | %(message)s\",\n    datefmt=\"%H:%M:%S\",\n    handlers=[\n        RotatingFileHandler(LOG_DIR / \"xinghe.log\", maxBytes=5*1024*1024, backupCount=3),\n        logging.StreamHandler(sys.stdout),\n    ]\n)\nfor noisy in [\"urllib3\", \"openai\", \"httpx\", \"requests\"]:\n    logging.getLogger(noisy).setLevel(logging.WARNING)\n\nlogger = logging.getLogger(\"XingHe\")\n\n# 保险库\n_VAULT_password=[REDACTED]\nimport unified_auth\nunified_auth.init(_VAULT_PASSWORD)\nfrom unified_aut",
